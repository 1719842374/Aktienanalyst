# Stock Analyst Pro — Environment Variables
# Nur für lokale Entwicklung. Auf pplx.app werden Keys als credentials= übergeben.

# Server
PORT=5000
NODE_ENV=production

# Financial Modeling Prep — kostenloser Tier (750 Calls/Tag)
# https://financialmodelingprep.com/developer/docs
FMP_API_KEY=your_fmp_key_here

# OpenRouter — für KI-Katalysatoren, Investmentthese, Risiko-Analyse
# https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# HINWEIS: Die Perplexity Finance API (external-tool CLI) funktioniert
# ausschließlich in der Perplexity Computer Sandbox.
# Auf pplx.app werden alle Keys über publish_website credentials= injiziert.
