# Stock Analyst Pro — Environment Variables
# Copy to .env and fill in your values

# Server
PORT=5000
NODE_ENV=production

# Anthropic API (for KI-Katalysatoren)
ANTHROPIC_API_KEY=sk-ant-...

# The finance API calls use the Perplexity Finance connector
# On Railway/self-hosted, you need to provide an alternative.
# Option 1: Use Financial Modeling Prep (FMP) API
# FMP_API_KEY=your_fmp_key_here
# Option 2: Keep using the external-tool CLI (only works in Perplexity sandbox)
